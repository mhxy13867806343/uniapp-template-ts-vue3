{
  "name": "uniapp-template-ts-vue3",
  "appid": "__UNI__TEMPLATE",
  "description": "uni-app template with Vue 3.5, TypeScript, Wot Design Uni and UnoCSS.",
  "versionName": "0.1.0",
  "versionCode": "100",
  "transformPx": false,
  "app-plus": {
    "usingComponents": true,
    "nvueCompiler": "uni-app",
    "compilerVersion": 3,
    "splashscreen": {
      "alwaysShowBeforeRender": true,
      "waiting": true,
      "autoclose": true,
      "delay": 0
    },
    "modules": {},
    "distribute": {
      "android": {},
      "ios": {}
    }
  },
  "h5": {
    "router": {
      "mode": "hash"
    }
  },
  "mp-weixin": {
    "appid": "",
    "setting": {
      "urlCheck": false,
      "es6": true
    },
    "usingComponents": true
  },
  "mp-alipay": {
    "usingComponents": true
  },
  "mp-toutiao": {
    "appid": "",
    "setting": {
      "urlCheck": false,
      "es6": true
    },
    "usingComponents": true
  },
  "app-harmony": {
    "usingComponents": true
  }
}
