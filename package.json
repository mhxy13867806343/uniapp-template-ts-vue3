{
  "name": "uniapp-template-ts-vue3",
  "version": "0.1.0",
  "description": "A reusable uni-app template for H5, mini programs and app targets.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev:h5": "uni -p h5 --mode development",
    "dev:app": "uni -p app --mode development",
    "dev:app-harmony": "uni -p app-harmony --mode development",
    "dev:mp-weixin": "uni -p mp-weixin --mode development",
    "dev:mp-alipay": "uni -p mp-alipay --mode development",
    "dev:mp-toutiao": "uni -p mp-toutiao --mode development",
    "build:h5": "uni build -p h5 --mode production",
    "build:github": "uni build -p h5 --mode github",
    "build:app": "uni build -p app --mode production",
    "build:app-harmony": "uni build -p app-harmony --mode production",
    "build:mp-weixin": "uni build -p mp-weixin --mode production",
    "build:mp-alipay": "uni build -p mp-alipay --mode production",
    "build:mp-toutiao": "uni build -p mp-toutiao --mode production",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-app-harmony": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-mp-alipay": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-alpha-5000820260430001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000820260430001",
    "@vue/devtools-api": "^6.6.4",
    "@vue/runtime-core": "^3.5.0",
    "dayjs": "^1.11.20",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "wot-design-uni": "latest"
  },
  "devDependencies": {
    "@dcloudio/types": "latest",
    "@dcloudio/uni-automator": "3.0.0-alpha-5000820260430001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000820260430001",
    "@types/node": "^22.0.0",
    "@uni-helper/unocss-preset-uni": "latest",
    "@vitejs/plugin-vue": "latest",
    "@vue/tsconfig": "latest",
    "eslint": "^9.0.0",
    "sass": "^1.80.0",
    "typescript": "^5.6.0",
    "unocss": "^0.65.0",
    "unplugin-auto-import": "^21.0.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.1.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
